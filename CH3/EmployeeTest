public class EmployeeTest {
    public static void main(String[] args) {
        Employee employee1 = new Employee("John", "Blue", 0.0);
        Employee employee2 = new Employee("Sophie", "Blue", 10.0);

        System.out.printf("Annual salary of%s is:%.2f%n", employee1.getFistName(), employee1.annualSalary());
        System.out.printf("Annual salary of%s is:%.2f%n", employee2.getFistName(), employee2.annualSalary());

        System.out.println("Adding 10% in salary" );
        employee1.adjustment(10);
        employee2.adjustment(10);

        System.out.printf("Annual salary of %s is: %.2f%n", employee1.getFistName(), employee1.annualSalary());
        System.out.printf("Annual salary of %s is: %.2f%n", employee2.getFistName(), employee2.annualSalary());
    }
}
